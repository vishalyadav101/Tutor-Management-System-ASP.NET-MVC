@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
}

<section style="background:var(--light);min-height:80vh;display:flex;align-items:center;padding:60px 0;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-5 col-md-7">
                <div class="text-center mb-4">
                    <a href="/" style="font-family:'Syne',sans-serif;font-size:1.8rem;font-weight:800;color:var(--primary);">Tuition<span style="color:var(--accent)">Hub</span></a>
                    <h4 style="font-family:'Syne',sans-serif;color:var(--primary);margin-top:20px;">Wapas Aaye! 👋</h4>
                    <p style="color:var(--muted);font-size:0.9rem;">Apne account mein login karein</p>
                </div>
                <div class="form-section">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger mb-3">❌ @ViewBag.Error</div>
                    }
                    @using (Html.BeginForm("Login", "Account", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Email Address</label>
                            <input type="email" name="Email" class="form-control" placeholder="aapka@email.com" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <div style="position:relative;">
                                <input type="password" name="Password" id="passInput" class="form-control" placeholder="Password dalein" required style="padding-right:44px;">
                                <button type="button" onclick="togglePass()" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--muted);cursor:pointer;">
                                    <i class="fa fa-eye" id="passEye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <label style="font-size:0.88rem;cursor:pointer;">
                                <input type="checkbox" name="RememberMe" style="margin-right:6px;"> Mujhe yaad rakho
                            </label>
                            <a href="#" style="font-size:0.88rem;color:var(--accent);">Password bhool gaye?</a>
                        </div>
                        <button type="submit" class="btn-primary-custom w-100" style="justify-content:center;">
                            <i class="fa fa-sign-in-alt"></i> Login Karein
                        </button>
                    }
                    <div style="text-align:center;margin-top:24px;padding-top:20px;border-top:1px solid var(--border);">
                        <p style="color:var(--muted);font-size:0.9rem;">Account nahi hai? <a href="/Account/Register" style="color:var(--accent);font-weight:600;">Register Karein</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>