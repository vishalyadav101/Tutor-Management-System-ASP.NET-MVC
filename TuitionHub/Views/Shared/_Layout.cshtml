<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - TuitionHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="~/Content/site.css" rel="stylesheet">
</head>
<body>

    <div class="announcement-bar">
        <i class="fa fa-bullhorn me-2"></i>
        TuitionHub pe 500+ verified tutors available hain! Aaj hi apna tutor dhundein.
    </div>

    <nav class="navbar navbar-tuition navbar-expand-lg">
        <div class="container">
            <a class="brand navbar-brand" href="/">Tuition<span>Hub</span></a>
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMain">
                <i class="fa fa-bars text-white"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Student/FindTutor">Tutors Dhundein</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/About">About Us</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Contact">Contact</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Faq">FAQ</a>
                    </li>
                </ul>
                <div class="d-flex gap-2 mt-2 mt-lg-0">
                    @if (Session["UserId"] != null)
                    {
                        string role = Session["Role"] != null ? Session["Role"].ToString() : "";
                        string dashUrl = role == "Admin" ? "/Admin/Dashboard" :
                                         role == "Tutor" ? "/Tutor/Dashboard" :
                                                            "/Student/Dashboard";
                        <a href="@dashUrl" class="btn-nav-login">Dashboard</a>
                        <a href="/Account/Logout" class="btn-nav-register">Logout</a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn-nav-login">Login</a>
                        <a href="/Account/Register" class="btn-nav-register">Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success">
                <i class="fa fa-check-circle me-2"></i>
                @TempData["SuccessMsg"]
            </div>
        </div>
    }
    @if (TempData["ErrorMsg"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-danger">
                <i class="fa fa-exclamation-circle me-2"></i>
                @TempData["ErrorMsg"]
            </div>
        </div>
    }

    @RenderBody()

    <footer>
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="footer-brand">Tuition<span>Hub</span></div>
                    <p style="font-size:0.88rem;line-height:1.7;max-width:280px;">
                        India ka sabse trusted tuition platform.
                    </p>
                </div>
                <div class="col-lg-2 col-6">
                    <h6>Quick Links</h6>
                    <a href="/">Home</a>
                    <a href="/Student/FindTutor">Tutors</a>
                    <a href="/Home/About">About Us</a>
                    <a href="/Home/Faq">FAQ</a>
                    <a href="/Home/Contact">Contact</a>
                </div>
                <div class="col-lg-2 col-6">
                    <h6>Students</h6>
                    <a href="/Account/Register">Register</a>
                    <a href="/Account/Login">Login</a>
                    <a href="/Student/FindTutor">Tutor Search</a>
                </div>
                <div class="col-lg-2 col-6">
                    <h6>Tutors</h6>
                    <a href="/Account/Register">Join as Tutor</a>
                    <a href="/Account/Login">Login</a>
                    <a href="/Tutor/Dashboard">Dashboard</a>
                </div>
                <div class="col-lg-2 col-6">
                    <h6>Support</h6>
                    <a href="/Home/Contact">Contact Us</a>
                    <a href="/Home/Faq">Help Center</a>
                </div>
            </div>
            <hr>
            <div class="d-flex flex-wrap justify-content-between footer-bottom">
                <span>&copy; 2024 TuitionHub. Sab rights reserved.</span>
                <span>Made for Students &amp; Tutors of India</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Scripts/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>