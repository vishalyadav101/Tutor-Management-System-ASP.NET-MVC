@* Save as: Views/Admin/EditTutor.cshtml *@
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Tutor Edit";
    ViewData["Active"] = "Tutors";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;">
            <a href="/Admin/Tutors" style="color:var(--muted);font-size:0.9rem;">← Tutors List</a>
            <span style="color:var(--muted);">/</span>
            <span style="font-size:0.9rem;color:var(--primary);">Edit Tutor</span>
        </div>

        <div class="form-section">
            <h4 style="font-family:'Syne',sans-serif;color:var(--primary);margin-bottom:4px;">Tutor Edit Karein</h4>
            <p style="color:var(--muted);font-size:0.88rem;margin-bottom:24px;">Tutor ki details update karein, verify ya block karein</p>

            @using (Html.BeginForm("EditTutor", "Admin", new { id = ViewBag.Tutor?.Id ?? 0 }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Pura Naam *</label>
                        <input type="text" name="FullName" class="form-control" value="@(ViewBag.Tutor?.FullName ?? "")" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email *</label>
                        <input type="email" name="Email" class="form-control" value="@(ViewBag.Tutor?.Email ?? "")" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone</label>
                        <input type="tel" name="Phone" class="form-control" value="@(ViewBag.Tutor?.Phone ?? "")">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">City</label>
                        <input type="text" name="City" class="form-control" value="@(ViewBag.Tutor?.City ?? "")">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <select name="Gender" class="form-select">
                            <option value="Male" @(ViewBag.Tutor?.Gender=="Male"?"selected":"")>Male</option>
                            <option value="Female" @(ViewBag.Tutor?.Gender=="Female"?"selected":"")>Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Qualification</label>
                        <select name="Qualification" class="form-select">
                            @foreach (var q in new[]{"B.Sc","B.Tech","B.Ed","M.Sc","M.Tech","M.Ed","MA","PhD"})
                            {
                                <option value="@q" @(ViewBag.Tutor?.Qualification==q?"selected":"")>@q</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Experience (Years)</label>
                        <input type="number" name="Experience" class="form-control" value="@(ViewBag.Tutor?.Experience ?? 0)" min="0" max="50">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Rating (0-5)</label>
                        <input type="number" name="Rating" class="form-control" value="@(ViewBag.Tutor?.Rating ?? 0)" min="0" max="5" step="0.1">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Subjects</label>
                        <input type="text" name="Subjects" class="form-control" value="@(ViewBag.Tutor?.Subjects ?? "")" placeholder="Maths, Physics, Chemistry">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Bio</label>
                        <textarea name="Bio" class="form-control" rows="3">@(ViewBag.Tutor?.Bio ?? "")</textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Verification Status</label>
                        <select name="IsVerified" class="form-select">
                            <option value="true" @(ViewBag.Tutor?.IsVerified==true?"selected":"")>✅ Verified</option>
                            <option value="false" @(ViewBag.Tutor?.IsVerified==false?"selected":"")>⏳ Pending</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Account Status</label>
                        <select name="IsActive" class="form-select">
                            <option value="true" @(ViewBag.Tutor?.IsActive==true?"selected":"")>✅ Active</option>
                            <option value="false" @(ViewBag.Tutor?.IsActive==false?"selected":"")>🚫 Blocked</option>
                        </select>
                    </div>

                    <div class="col-12 d-flex gap-3 mt-2 flex-wrap">
                        <button type="submit" class="btn-primary-custom">
                            <i class="fa fa-save"></i> Save Changes
                        </button>
                        <a href="/Admin/Tutors" class="btn-secondary-custom">Cancel</a>
                        <a href="/Admin/DeleteTutor/@(ViewBag.Tutor?.Id ?? 0)"
                           class="btn-action btn-delete" style="padding:12px 24px;border-radius:10px;"
                           onclick="return confirm('Is tutor ko permanently delete karein?')">
                            Delete Tutor
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
