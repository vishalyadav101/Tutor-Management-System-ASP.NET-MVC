@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "About Us";
}

<section style="background:linear-gradient(135deg,var(--primary),#0f3460);color:white;padding:70px 0;">
    <div class="container text-center">
        <div class="section-tag" style="background:rgba(233,69,96,0.2);color:#ff8fa3;">Hamare Baare Mein</div>
        <h1 style="color:white;font-size:3rem;font-family:'Syne',sans-serif;font-weight:800;">About <span style="color:var(--gold)">TuitionHub</span></h1>
        <p style="color:rgba(255,255,255,0.7);max-width:600px;margin:16px auto 0;">India ka trusted tuition platform.</p>
    </div>
</section>

<section style="background:white;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="section-tag">Hamara Mission</div>
                <h2 class="section-title">Quality Education <span style="color:var(--accent)">Sabke Liye</span></h2>
                <p style="color:var(--muted);line-height:1.8;">TuitionHub ka mission hai ki har student ko uske level ke hisaab se perfect tutor mile — chahe woh Maths padna chahta ho, Science, ya koi bhi subject.</p>
                <p style="color:var(--muted);line-height:1.8;margin-top:14px;">2024 mein shuru hua TuitionHub aaj 500+ verified tutors aur 2000+ students ko connect kar raha hai poore India mein.</p>
                <div class="row g-3 mt-2">
                    <div class="col-4 text-center">
                        <div style="font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--accent);">500+</div>
                        <div style="font-size:0.82rem;color:var(--muted);">Tutors</div>
                    </div>
                    <div class="col-4 text-center">
                        <div style="font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--accent);">2000+</div>
                        <div style="font-size:0.82rem;color:var(--muted);">Students</div>
                    </div>
                    <div class="col-4 text-center">
                        <div style="font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--accent);">20+</div>
                        <div style="font-size:0.82rem;color:var(--muted);">Subjects</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div style="background:var(--light);border-radius:20px;padding:40px;border:2px solid var(--border);">
                    <div class="d-flex gap-4 mb-4">
                        <div style="width:56px;height:56px;background:rgba(233,69,96,0.1);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;">🎯</div>
                        <div>
                            <h5 style="font-family:'Syne',sans-serif;color:var(--primary);margin-bottom:6px;">Our Vision</h5>
                            <p style="color:var(--muted);font-size:0.9rem;margin:0;">Har student ko unka dream achieve karne mein help karna.</p>
                        </div>
                    </div>
                    <div class="d-flex gap-4 mb-4">
                        <div style="width:56px;height:56px;background:rgba(245,166,35,0.12);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;">💡</div>
                        <div>
                            <h5 style="font-family:'Syne',sans-serif;color:var(--primary);margin-bottom:6px;">Innovation</h5>
                            <p style="color:var(--muted);font-size:0.9rem;margin:0;">Technology se education ko easy banao.</p>
                        </div>
                    </div>
                    <div class="d-flex gap-4">
                        <div style="width:56px;height:56px;background:rgba(46,204,113,0.1);border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;">🤝</div>
                        <div>
                            <h5 style="font-family:'Syne',sans-serif;color:var(--primary);margin-bottom:6px;">Trust</h5>
                            <p style="color:var(--muted);font-size:0.9rem;margin:0;">Har tutor admin-verified hai. Parents aur students ki safety humari priority hai.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>