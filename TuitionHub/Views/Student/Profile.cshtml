@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "My Profile";
    ViewData["Active"] = "Profile";

    var student = ViewBag.Student as TuitionHub.Models.User;
    string fullName = student != null ? student.FullName : Session["Username"] != null ? Session["Username"].ToString() : "";
    string email = student != null ? student.Email : "";
    string phone = student != null ? student.Phone : "";
    string city = student != null ? student.City : "";
    string gender = student != null ? student.Gender : "";
    string cls = student != null ? student.Class : "";
    string reqSub = student != null ? student.RequiredSubject : "";
    string initials = student != null ? student.Initials : "??";
    bool isActive = student != null ? student.IsActive : true;
}

<div class="row g-4">

    <div class="col-lg-4">
        <div class="table-tuition" style="padding:0;overflow:hidden;">
            <div style="background:linear-gradient(135deg,var(--primary),#0f3460);padding:36px 24px;text-align:center;">
                <div style="width:90px;height:90px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:white;margin:0 auto 16px;">
                    @initials
                </div>
                <h4 style="font-family:'Syne',sans-serif;color:white;margin-bottom:4px;">
                    @fullName
                </h4>
                <p style="color:rgba(255,255,255,0.6);font-size:0.85rem;margin-bottom:12px;">
                    Student - TuitionHub
                </p>
                <span class="badge-status @(isActive ? "badge-active" : "badge-inactive")"
                      style="display:inline-flex;align-items:center;gap:6px;">
                    @if (isActive)
                    {
                        <i class="fa fa-check-circle"></i>
                        <span>Active Account</span>
                    }
                    else
                    {
                        <i class="fa fa-times-circle"></i>
                        <span>Inactive</span>
                    }
                </span>
            </div>
            <div style="padding:24px;">
                <div style="display:flex;flex-direction:column;gap:14px;">
                    <div style="display:flex;gap:12px;align-items:center;">
                        <i class="fa fa-envelope"
                           style="color:var(--accent);width:20px;"></i>
                        <div>
                            <div style="font-size:0.75rem;color:var(--muted);">Email</div>
                            <div style="font-weight:600;font-size:0.9rem;">@email</div>
                        </div>
                    </div>
                    <div style="display:flex;gap:12px;align-items:center;">
                        <i class="fa fa-phone"
                           style="color:var(--accent);width:20px;"></i>
                        <div>
                            <div style="font-size:0.75rem;color:var(--muted);">Phone</div>
                            <div style="font-weight:600;font-size:0.9rem;">
                                @(string.IsNullOrEmpty(phone) ? "Not added" : phone)
                            </div>
                        </div>
                    </div>
                    <div style="display:flex;gap:12px;align-items:center;">
                        <i class="fa fa-map-marker-alt"
                           style="color:var(--accent);width:20px;"></i>
                        <div>
                            <div style="font-size:0.75rem;color:var(--muted);">City</div>
                            <div style="font-weight:600;font-size:0.9rem;">
                                @(string.IsNullOrEmpty(city) ? "Not added" : city)
                            </div>
                        </div>
                    </div>
                    <div style="display:flex;gap:12px;align-items:center;">
                        <i class="fa fa-book"
                           style="color:var(--accent);width:20px;"></i>
                        <div>
                            <div style="font-size:0.75rem;color:var(--muted);">Class</div>
                            <div style="font-weight:600;font-size:0.9rem;">
                                @(string.IsNullOrEmpty(cls) ? "Not added" : "Class " + cls)
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="form-section">
            <h4 style="font-family:'Syne',sans-serif;color:var(--primary);margin-bottom:4px;">
                Profile Edit Karein
            </h4>
            <p style="color:var(--muted);font-size:0.88rem;margin-bottom:24px;">
                Apni details update karein
            </p>

            @using (Html.BeginForm("UpdateProfile", "Student", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Pura Naam</label>
                        <input type="text" name="FullName" class="form-control"
                               value="@fullName" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone</label>
                        <input type="tel" name="Phone" class="form-control"
                               value="@phone"
                               placeholder="+91 XXXXX XXXXX">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">City</label>
                        <input type="text" name="City" class="form-control"
                               value="@city"
                               placeholder="Aapki city">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Gender</label>
                        <select name="Gender" class="form-select">
                            <option value="Male"
                                    @(gender == "Male" ? "selected" : "")>
                                Male
                            </option>
                            <option value="Female"
                                    @(gender == "Female" ? "selected" : "")>
                                Female
                            </option>
                            <option value="Other"
                                    @(gender == "Other" ? "selected" : "")>
                                Other
                            </option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Class / Standard</label>
                        <select name="Class" class="form-select">
                            <option value="">Select Class</option>
                            @for (int i = 1; i <= 12; i++)
                            {
                                <option value="@i"
                                        @(cls == i.ToString() ? "selected" : "")>
                                    Class @i
                                </option>
                            }
                            <option value="College"
                                    @(cls == "College" ? "selected" : "")>
                                College
                            </option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Required Subject</label>
                        <input type="text" name="RequiredSubject" class="form-control"
                               value="@reqSub"
                               placeholder="e.g. Maths">
                    </div>
                    <div class="col-12">
                        <hr style="border-color:var(--border);">
                        <p style="font-family:'Syne',sans-serif;font-size:0.9rem;color:var(--primary);font-weight:700;margin-bottom:0;">
                            Password Change (optional)
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Naya Password</label>
                        <input type="password" name="NewPassword" class="form-control"
                               placeholder="Khali chhodein agar change nahi karna">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Confirm Password</label>
                        <input type="password" name="ConfirmPassword" class="form-control"
                               placeholder="Dobara likhein">
                    </div>
                    <div class="col-12 d-flex gap-3">
                        <button type="submit" class="btn-primary-custom">
                            <i class="fa fa-save me-2"></i> Save Changes
                        </button>
                        <a href="/Student/Dashboard" class="btn-secondary-custom">
                            Cancel
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>